# Home Assistant Configuration
# Required: Your Home Assistant instance URL
HASS_HOST=http://homeassistant.local:8123

# Required: Long-lived access token from Home Assistant
# Generate at: http://homeassistant.local:8123/profile (Security section)
HASS_TOKEN=your_long_lived_access_token_here

# Server Configuration (Optional)
# Name of the MCP server
SERVER_NAME=Home Assistant MCP

# Version of the MCP server
SERVER_VERSION=2.0.0

# Cache Configuration (Optional)
# Time-to-live for bulk states cache in seconds
CACHE_TTL_STATES=30

# Time-to-live for individual entity cache in seconds
CACHE_TTL_ENTITY=10

# Logging Configuration (Optional)
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
